
from telegram import Update, ReplyKeyboardMarkup, KeyboardButton, WebAppInfo
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, ContextTypes, filters

TOKEN = "8841536533:AAGkvtq2cT_BXSOsFYQ57kZNSM9o8rZHwGA"
SITE_URL = "https://sushi-asaki24.ru"

menu_keyboard = ReplyKeyboardMarkup(
    [
        ["🍱 Сеты", "🍣 Роллы"],
        ["🔥 Горячие роллы", "🧀 Запеченные роллы"],
        ["🥪 Сэндвичи", "🍙 Онигири"],
        ["🍤 Закуски", "🍜 Wok"],
        ["🍣 Суши", "🍥 Гунканы"],
        ["🥗 Салаты", "🥤 Напитки"],
        ["🍰 Десерты", "🥫 Соусы"],
        ["🔥 Акции", "📞 Контакты"],
        [KeyboardButton("🍣 Открыть меню", web_app=WebAppInfo(url=SITE_URL))]
    ],
    resize_keyboard=True
)

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🍣 Добро пожаловать в Асаки!\nВыберите раздел или откройте полное меню:",
        reply_markup=menu_keyboard
    )

async def handle_menu(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text

    await update.message.reply_text(
        f"{text}\n\nНажмите «🍣 Открыть меню», чтобы посмотреть товары и оформить заказ."
    )

app = ApplicationBuilder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_menu))

print("Бот запущен...")
app.run_polling()
