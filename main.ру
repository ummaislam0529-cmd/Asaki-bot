        await update.message.reply_text(
            "⭐ Оставить отзыв:\n\n"
            "https://2gis.ru/"
        )

    elif text == "📞 Контакты":

        await update.message.reply_text(
            "📍 Красноярск\n"
            "ул. Космонавтов 17г\n\n"
            "📞 Телефон:\n"
            "209-27-07"
        )

    elif text == "📲 WhatsApp":

        await update.message.reply_text(
            "📲 WhatsApp:\n"
            "https://wa.me/79994462155"
        )

    elif text == "💬 MAX":

        await update.message.reply_text(
            "💬 MAX:\n"
            "Ссылка появится позже"
        )

    else:

        await update.message.reply_text(
            f"{text}\n\nНажмите «🍣 Открыть меню» для заказа."
