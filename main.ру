async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🍣 Добро пожаловать в АСАКИ!\n\n"
        "Свежие роллы, сеты и Wok с доставкой 🚀\n\n"
        "Выберите раздел:",
        reply_markup=menu_keyboard
    )

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text

    if text == "🔥 Акции":
        await update.message.reply_text(
            "🔥 АКЦИИ АСАКИ\n\n"
            "🎁 Самовывоз — скидка 10%\n\n"
            "🎂 День рождения:\n"
            "Ролл «Калифорния лайт с крабом» в подарок\n\n"
            "⭐ Отзыв в Яндекс:\n"
            "Онигири в подарок"
        )

    elif text == "⭐ Оставить отзыв":
        await update.message.reply_text(
            "⭐ Спасибо за отзыв!\n\n"
            "Оставить отзыв в Яндекс:\n"
            f"{YANDEX_REVIEW_URL}"
        )

    elif text == "📞 Контакты":
        await update.message.reply_text(
            "📞 АСАКИ\n\n"
            "📍 Адрес:\n"
            "г. Красноярск, ул. Космонавтов 17г\n\n"
            "📱 Телефон:\n"
            "209-27-07\n\n"
            "🕐 График работы:\n"
            "Пн–Пт: 18:00 — 06:00\n"
            "Сб–Вс: 18:00 — 08:00\n\n"
            "🚗 Доставка по городу"
        )

    elif text == "📲 WhatsApp":
        await update.message.reply_text(
            "📲 Написать в WhatsApp:\n"
            f"{WHATSAPP_URL}"
        )

    elif text == "💬 MAX":
        await update.message.reply_text(
            "💬 Мы в MAX / Telegram:\n"
            f"{MAX_URL}"
        )

    else:
        await update.message.reply_text(
            f"{text}\n\n"
            "Чтобы посмотреть товары и оформить заказ, нажмите кнопку:\n"
            "🍣 Открыть меню"
        )

app = ApplicationBuilder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))

print("Бот АСАКИ запущен...")
app.run_polling()
